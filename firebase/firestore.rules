rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Own document : full read/write
      allow get, write: if request.auth != null && request.auth.uid == userId;

      // Single-document read for any volunteer profile
      allow get: if request.auth != null && resource.data.role == 'volunteer';

      // Collection query needed to pick a random volunteer at student registration
      allow list: if request.auth != null;
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
