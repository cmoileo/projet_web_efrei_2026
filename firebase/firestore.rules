rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allows only authenticated users to read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default deny for everything else for now
    match /{document=**} {
      allow read, write: if false;
    }
  }
}