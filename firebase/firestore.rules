rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Own document : full read/write
      allow get, write: if request.auth != null && request.auth.uid == userId;

      // Single-document read for any volunteer profile
      allow get: if request.auth != null && resource.data.role == 'volunteer';

      // Volunteer can read a student document if that student is assigned to them
      allow get: if request.auth != null &&
        resource.data.role == 'student' &&
        resource.data.volunteer_id == request.auth.uid;

      // Collection query needed to pick a random volunteer at student registration
      allow list: if request.auth != null;
    }

    match /tasks/{taskId} {
      // Lecture : bénévole créateur OU élève assigné
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.createdBy ||
         request.auth.uid == resource.data.assignedTo);

      // Création : bénévole uniquement
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.createdBy;

      // Modification :
      // - Bénévole créateur peut tout modifier
      // - Élève assigné peut uniquement modifier le champ status et updatedAt
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.createdBy ||
        (request.auth.uid == resource.data.assignedTo &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']))
      );

      // Suppression : bénévole créateur uniquement
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.createdBy;
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
